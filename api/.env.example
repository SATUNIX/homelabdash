# Application environment
# "development" enables Flask debug mode; use "production" for all deployments.
APP_ENV=production

# Internal port the Flask/Gunicorn server binds to (not exposed outside Docker).
PORT=4000

# Absolute path to the SQLite database file inside the container.
INDEX_DATABASE=/data/index-dashboard.db

# Path to the primary service catalog YAML mounted into the container.
INDEX_SEED_CATALOG_PATH=/seed/catalog.yml

# Optional: paths to homepage-compatible YAML files for catalog bootstrapping.
# If these files are absent the catalog is seeded from catalog.yml only.
# INDEX_SEED_HOMEPAGE_SERVICES_PATH=/seed/homepage-services.yml
# INDEX_SEED_HOMEPAGE_BOOKMARKS_PATH=/seed/homepage-bookmarks.yml

# Active health probe settings.
INDEX_PROBE_TIMEOUT_SECONDS=4
INDEX_PROBE_INTERVAL_SECONDS=60

# How long probe history is retained and how many data points to keep per service.
INDEX_HISTORY_RETENTION_HOURS=48
INDEX_MAX_HISTORY_POINTS=48

# Bootstrap admin account created on first run when no users exist.
INDEX_BOOTSTRAP_ADMIN_USERNAME=admin
INDEX_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Public-facing URL for this dashboard, used when building redirect URLs.
INDEX_PUBLIC_BASE_URL=http://localhost:18493

# Base URL of the authentication gateway (e.g. https://auth.example.com).
# Used to build the logout redirect link shown in the UI.
# Leave empty to disable the logout button.
INDEX_AUTH_GATEWAY_URL=

# Path to the Docker socket for topology discovery.
# Remove the socket volume mount from compose.yml to disable topology entirely.
INDEX_DOCKER_SOCKET_PATH=/var/run/docker.sock

# How long the topology snapshot is cached (seconds).
INDEX_TOPOLOGY_CACHE_TTL_SECONDS=20
